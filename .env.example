# 环境变量配置示例
# 复制为 .env 后按实际环境填写
# 所有启动方式均通过环境变量驱动，不修改源码配置文件

# ------------------------------
# Spring / Profile
# ------------------------------
# 可选: prod / dev / mysql / screenshot / test
# 正式运行请使用 prod；screenshot/test 仅用于截图、E2E 或测试。
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# ------------------------------
# 数据库
# ------------------------------
# 正式运行使用 MySQL，数据库名与 sql/schema.sql 保持一致: campus_material
DB_URL=jdbc:mysql://127.0.0.1:3306/campus_material?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_POOL_MIN_IDLE=2
DB_POOL_MAX_SIZE=10
DB_POOL_CONNECTION_TIMEOUT=30000
DB_POOL_VALIDATION_TIMEOUT=5000
DB_POOL_IDLE_TIMEOUT=600000
DB_POOL_MAX_LIFETIME=1800000
DB_POOL_INITIALIZATION_FAIL_TIMEOUT=1

# ------------------------------
# JWT
# ------------------------------
# 非测试环境必须提供不少于 32 字节的高强度随机密钥
# PowerShell 生成示例:
# [Convert]::ToBase64String((1..48 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=replace_with_a_random_secret_at_least_32_bytes_long
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
JWT_MULTI_DEVICE_LOGIN=true
JWT_CLEANUP_CRON=0 0/30 * * * ?

# ------------------------------
# CORS
# ------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With
CORS_ALLOW_CREDENTIALS=false

# ------------------------------
# 限流
# ------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TRUST_FORWARD_HEADERS=false
RATE_LIMIT_LOGIN_CAPACITY=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_REFRESH_CAPACITY=10
RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
RATE_LIMIT_HIGH_RISK_CAPACITY=20
RATE_LIMIT_HIGH_RISK_WINDOW_SECONDS=60

# ------------------------------
# 日志与管理端口
# ------------------------------
APP_LOG_DIR=./logs
MANAGEMENT_SERVER_ADDRESS=127.0.0.1
MANAGEMENT_SERVER_PORT=18080

# ------------------------------
# 文档与调试开关
# ------------------------------
KNIFE4J_ENABLE=true
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true
MYBATIS_LOG_IMPL=org.apache.ibatis.logging.nologging.NoLoggingImpl

# ------------------------------
# Sentry / 观测
# ------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.0

# ------------------------------
# 前端 Vite 变量
# ------------------------------
VITE_API_TARGET=http://127.0.0.1:8080
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_SENTRY_TRACES_SAMPLE_RATE=0
