# 环境变量配置示例
# 复制此文件为 .env 并按实际情况修改
# ========================================

# ---- 数据库配置 ----
DB_URL=jdbc:mysql://127.0.0.1:3306/campus_material?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=Lyk20041102.

# ---- JWT 配置 ----
# 生产环境请务必使用高强度随机密钥（至少 32 字节）
JWT_SECRET=PLEASE_CHANGE_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_32_BYTES
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
JWT_MULTI_DEVICE_LOGIN=true

# ---- CORS 配置 ----
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Spring 配置 ----
# 默认 dev 为内置 H2 开箱即用；需要连接真实 MySQL 时改为 mysql
SPRING_PROFILES_ACTIVE=mysql
